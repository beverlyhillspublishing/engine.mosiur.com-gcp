# ==============================================================================
# TechyPark Email Marketing Platform — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values before deploying.
#
# For GKE deployment (used by GET.sh), these values are loaded as Kubernetes
# secrets from the .env file at deploy time.
# ==============================================================================

# ─── APP ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://app.yourdomain.com
API_URL=https://api.yourdomain.com
TRACKING_BASE_URL=https://api.yourdomain.com

# ─── DATABASE (GKE in-cluster PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://techypark:localpassword123@postgres-service:5432/techypark

# PostgreSQL init credentials (used by postgres Docker container)
POSTGRES_DB=techypark
POSTGRES_USER=techypark
POSTGRES_PASSWORD=localpassword123

# ─── REDIS (GKE in-cluster Redis) ─────────────────────────────────────────────
REDIS_URL=redis://redis-service:6379

# ─── AUTHENTICATION ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-32-byte-random-secret-access
JWT_REFRESH_SECRET=replace-with-32-byte-random-secret-refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── ENCRYPTION ────────────────────────────────────────────────────────────────
# Used to encrypt email provider credentials at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-32-char-encryption-key-here

# ─── STRIPE BILLING ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_GROWTH=price_...
STRIPE_PRICE_ID_PRO=price_...

# ─── GOOGLE CLOUD STORAGE ──────────────────────────────────────────────────────
# Used for CSV import file uploads and email image assets
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=techypark-assets
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcs-key.json

# ─── SYSTEM EMAIL (for transactional emails: password resets, invites) ─────────
SYSTEM_SMTP_HOST=smtp.sendgrid.net
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=apikey
SYSTEM_SMTP_PASS=SG.your-sendgrid-api-key-here
SYSTEM_FROM_EMAIL=noreply@yourdomain.com

# ─── NEXT.JS (frontend — build-time ARG) ───────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── LOGGING ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
PORT=3001

# ─── SOCIAL AUTH ───────────────────────────────────────────────────────────────
# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/v1/auth/google/callback

# Apple Sign In
APPLE_CLIENT_ID=com.yourcompany.app
APPLE_TEAM_ID=ABCDE12345
APPLE_KEY_ID=ABCDE12345
APPLE_PRIVATE_KEY=base64-encoded-apple-auth-key-p8-contents
APPLE_REDIRECT_URI=https://api.yourdomain.com/api/v1/auth/apple/callback

# WebAuthn / Passkeys
RP_ID=yourdomain.com
RP_NAME=TechyPark
RP_ORIGIN=https://app.yourdomain.com

# ─── AI EMAIL BUILDER ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096

# ─── INBOUND EMAIL (Forward-to-Import) ─────────────────────────────────────────
# Domain where MX records point for inbound email routing
INBOUND_EMAIL_DOMAIN=icloud.mosiur.com
# HMAC key for verifying inbound webhook (from Mailgun/SendGrid dashboard)
INBOUND_WEBHOOK_SECRET=your-inbound-hmac-secret
# Mailgun specific signing key (from Mailgun dashboard → Webhooks)
MAILGUN_INBOUND_SIGNING_KEY=your-mailgun-signing-key

# ─── MAIL SYNC (IMAP) ──────────────────────────────────────────────────────────
# How often to sync all IMAP accounts (milliseconds, default 15 minutes)
MAIL_SYNC_INTERVAL_MS=900000
